@page "/hieu-chinh-phieu-xuat"
@using BlazorServerApp.Models
@using Microsoft.EntityFrameworkCore
@inject BlazorServerApp.Data.AppDbContext _context
@inject IJSRuntime JS

<h3>Hiệu Chỉnh Thông Tin Phiếu Xuất</h3>
<br />
<EditForm Model="@formModel" OnValidSubmit="Save">
    <DataAnnotationsValidator />
    <ValidationSummary />
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert aler">@errorMessage</div>
    }

    <div class="row mb-2">
        <div class="col-md-4">
            <label>Số phiếu xuất: </label>
            <InputSelect class="form-control" @bind-Value="formModel.SoPhieuXuatKho">
                <option value="">-- Chọn số phiếu xuất --</option>
                @foreach (var phieu in soPhieuGoc)
                {
                    <option value="@phieu">@phieu</option>
                }
            </InputSelect>
        </div>
        <div class="col-md-4">
            <label>Kho: </label>
            <InputSelect class="form-control" @bind-Value="formModel.KhoId">
                <option value="0">-- Chọn kho --</option>
                @foreach (var kho in khos)
                {
                    <option value="@kho.Id">@kho.TenKho</option>
                }
            </InputSelect>
        </div>
    </div>
    <div class="row mb-2">
        <div class="col-md-4">
            <label>Ngày xuất: </label>
            <InputDate @bind-Value="formModel.NgayXuatKho" class="form-control" />
        </div>
    </div>
    <br />
    <button type="submit" class="btn btn-primary">Tạo hiệu chỉnh</button>
</EditForm>

<hr />
<table class="table table-bordered">
    <thead class="table-light">
        <tr>
            <th>Số phiếu xuất</th>
            <th>Kho</th>
            <th>Ngày xuất</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var xnkPhieuXuat in xnkPhieuXuats)
        {
            <tr>
                <td>@xnkPhieuXuat.SoPhieuXuatKho</td>
                <td>@xnkPhieuXuat.Kho?.TenKho</td>
                <td>@xnkPhieuXuat.NgayXuatKho.ToString("dd/MM/yyyy")</td>
                <td>
                    <a class="btn btn-secondary btn-sm ms-1" href="/hieu-chinh-chi-tiet-phieu-xuat/@xnkPhieuXuat.Id">Hiệu chỉnh</a>
                    <button class="btn btn-danger btn-sm" @onclick="() => confirmDelete(xnkPhieuXuat.Id)">Xóa</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<XnkPhieuXuat> xnkPhieuXuats = new();
    private XnkPhieuXuat formModel = new();
    private List<Kho> khos = new();
    private string? errorMessage;
    private List<string> soPhieuGoc = new();

    protected override async Task OnParametersSetAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        xnkPhieuXuats = await _context.XnkPhieuXuats
            .Include(k => k.Kho)
            .ToListAsync();
        khos = await _context.Khos.ToListAsync();
        soPhieuGoc = await _context.PhieuXuats
            .Select(p => p.SoPhieuXuatKho)
            .Distinct()
            .ToListAsync();
    }

    private async Task Save()
    {
        errorMessage = null;
        formModel.SoPhieuXuatKho = formModel.SoPhieuXuatKho?.Trim();

        if (string.IsNullOrWhiteSpace(formModel.SoPhieuXuatKho))
        {
            errorMessage = "Số phiếu xuất không được để trống";
            return;
        }

        if (formModel.KhoId == 0)
        {
            errorMessage = "Phải chọn kho.";
            return;
        }

        if (formModel.NgayXuatKho == default)
        {
            errorMessage = "Phải chọn ngày xuất.";
            return;
        }

        bool tonTaiPhieuGoc = await _context.PhieuXuats
            .AnyAsync(p => p.SoPhieuXuatKho.Trim() == formModel.SoPhieuXuatKho);

        if (!tonTaiPhieuGoc)
        {
            errorMessage = "Không tìm thấy phiếu xuất gốc để hiệu chỉnh";
            return;
        }
        _context.XnkPhieuXuats.Add(formModel);
        await _context.SaveChangesAsync();

        formModel = new XnkPhieuXuat();
        await LoadData();
    }

    private async Task Delete(int id)
    {
        var xnkPhieuXuat = await _context.XnkPhieuXuats.FindAsync(id);

        if (xnkPhieuXuat != null)
        {
            _context.XnkPhieuXuats.Remove(xnkPhieuXuat);
            await _context.SaveChangesAsync();
            await LoadData();
        }
    }

    private async Task confirmDelete(int id)
    {
        if (await JS.InvokeAsync<bool>("confirm", "Bạn có chắc muốn xóa"))
        {
            await Delete(id);
        }
    }
}
